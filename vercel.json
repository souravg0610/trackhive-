{
  "functions": {
    "api/*.ts": { "runtime": "@vercel/node@3.2.21" }
  },
  "rewrites": [
    { "source": "/api/v1/auth/signup",                 "destination": "/api/auth" },
    { "source": "/api/v1/auth/signin",                 "destination": "/api/auth" },
    { "source": "/api/v1/auth/refresh",                "destination": "/api/auth" },
    { "source": "/api/v1/auth/me",                     "destination": "/api/auth" },
    { "source": "/api/v1/auth/forgot-password",        "destination": "/api/auth" },
    { "source": "/api/v1/employees/bulk-import",       "destination": "/api/employees" },
    { "source": "/api/v1/employees/:id/temp-password", "destination": "/api/employees" },
    { "source": "/api/v1/employees/:id",               "destination": "/api/employees" },
    { "source": "/api/v1/employees",                   "destination": "/api/employees" },
    { "source": "/api/v1/attendance/today",            "destination": "/api/attendance" },
    { "source": "/api/v1/attendance/all",              "destination": "/api/attendance" },
    { "source": "/api/v1/attendance/punch-in",         "destination": "/api/attendance" },
    { "source": "/api/v1/attendance/punch-out",        "destination": "/api/attendance" },
    { "source": "/api/v1/attendance",                  "destination": "/api/attendance" },
    { "source": "/api/v1/visits/:id",                  "destination": "/api/visits" },
    { "source": "/api/v1/visits",                      "destination": "/api/visits" },
    { "source": "/api/v1/tasks/:id",                   "destination": "/api/tasks" },
    { "source": "/api/v1/tasks",                       "destination": "/api/tasks" },
    { "source": "/api/v1/leaves/pending",              "destination": "/api/leaves" },
    { "source": "/api/v1/leaves/:id",                  "destination": "/api/leaves" },
    { "source": "/api/v1/leaves",                      "destination": "/api/leaves" },
    { "source": "/api/v1/shifts/:id",                  "destination": "/api/shifts" },
    { "source": "/api/v1/shifts",                      "destination": "/api/shifts" },
    { "source": "/api/v1/payroll/payslips",            "destination": "/api/payroll" },
    { "source": "/api/v1/geofences/:id",               "destination": "/api/geofences" },
    { "source": "/api/v1/geofences",                   "destination": "/api/geofences" },
    { "source": "/api/v1/notifications/:id",           "destination": "/api/notifications" },
    { "source": "/api/v1/notifications",               "destination": "/api/notifications" },
    { "source": "/api/v1/documents/:id",               "destination": "/api/documents" },
    { "source": "/api/v1/documents",                   "destination": "/api/documents" },
    { "source": "/api/v1/companies/org-settings",      "destination": "/api/companies" },
    { "source": "/(.*)",                               "destination": "/index.html" }
  ]
}